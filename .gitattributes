# Line endings: LF everywhere (containers + cross-platform)
* text=auto eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
